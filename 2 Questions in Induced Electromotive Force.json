    "type": "Question",
    "name": "Question 50 @ 2017/2018",
    "Question": {
      "content": "Faraday's law of electromagnetic induction is expressed as:",
      "type": "OBJ",
      "options": [
        "\\(E = \\frac{d\\Phi_B}{dt}\\)",
        "\\(E = -\\frac{d\\Phi_B}{dt}\\)",
        "\\(E = \\int \\Phi_B dt\\)",
        "\\( -\\int \\Phi_B dt\\)"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "\\(E = -\\frac{d\\Phi_B}{dt}\\)"
    },
    "Explanation": {
      "type": "string",
      "content": "Faraday's law states the induced EMF \\( E = -\\frac{d\\Phi_B}{dt} \\), where \\( \\Phi_B \\) is the magnetic flux, with the negative sign indicating Lenz's law."
    },
    "topic": [
      "Faraday's Law of Induction",
      "Electromagnetism",
      "Magnetic Fields",
      "Induced Electromotive Force"
    ]
