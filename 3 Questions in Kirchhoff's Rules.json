  {
    "type": "Question",
    "name": "Question 4 @ 2023/2024",
    "Question": {
      "content": "Which of the equations best describes Kirchhoff's junction rule?",
      "type": "OBJ",
      "options": [
        "ΣI = 0",
        "I2 = I + I1",
        "0 + I1 = I2",
        "I - 0 = I1"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "ΣI = 0"
    },
    "Explanation": {
      "type": "string",
      "content": "<p>Kirchhoff's junction rule states that the sum of currents entering a junction equals the sum of currents leaving it, which is expressed as\\(\\Sigma I = 0\\).</p>"
    },
    "topic": [
      "DC Circuits",
      "Electric Current",
      "Kirchhoff's Rules"
    ]
  },
  {
    "type": "Question",
    "name": "Question 5 @ 2023/2024",
    "Question": {
      "content": "Which of these equations best describes Kirchhoff's loop rule?",
      "type": "OBJ",
      "options": [
        "Σ(E + IR) = 0",
        "ΣV - IR",
        "ΣV - E = R",
        "V = I/R"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "Σ(E + IR) = 0"
    },
    "Explanation": {
      "type": "string",
      "content": "<p>Kirchhoff's loop rule states that the sum of all electromotive forces (E) and voltage drops (IR) around a closed loop is zero, expressed as\\(\\Sigma (E + IR) = 0\\).</p>"
    },
    "topic": [
      "Kirchhoff's Rules",
      "DC Circuits",
      "Electric Potential"
    ]
  },
