    "type": "Question",
    "name": "Question 4 @ 2019/2020",
    "Question": {
      "content": "A resistor has 5mA current at 10V. What current flows at 20V?",
      "type": "OBJ",
      "options": [
        "2mA",
        "5mA",
        "10mA",
        "50mA"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "10mA"
    },
    "Explanation": {
      "type": "string",
      "content": "\\(R = \\frac{V}{I} = \\frac{10V}{5mA} = 2k\\Omega\\) At 20V: \\(I = \\frac{V}{R} = \\frac{20V}{2k\\Omega} = 10mA\\)"
    },
    "topic": [
      "Electric Current and Resistance",
      "DC Circuits",
      "Ohm's Law"
    ]
  },
  {
    "type": "Question",
    "name": "Question 6 @ 2019/2020",
    "Question": {
      "content": "Two copper wires have the same cross-sectional area but lengths L (X) and 2L (Y). The ratio Ry/Rx is:",
      "type": "OBJ",
      "options": [
        "1/1",
        "1/2",
        "2/1",
        "1/4",
        "4/1"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "2/1"
    },
    "Explanation": {
      "type": "string",
      "content": "Resistance \\(R = \\rho \\frac{L}{A}\\). Since \\(\\rho\\) and \\(A\\) are equal: \\(\\frac{R_Y}{R_X} = \\frac{2L}{L} = 2\\)"
    },
    "topic": [
      "Electricity & Magnetism",
      "Electric Current and Resistance",
      "Ohm's Law"
    ]
  },
  {
    "type": "Question",
    "name": "Question 7 @ 2019/2020",
    "Question": {
      "content": "Kirchhoff’s first rule is:",
      "type": "OBJ",
      "options": [
        "ΣT = 0",
        "ΣR = 0",
        "ΣV = 0",
        "ΣI = 0"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "ΣI = 0"
    },
    "Explanation": {
      "type": "string",
      "content": "Kirchhoff’s junction rule states that the algebraic sum of currents entering a junction is zero: \\(\\sum I = 0\\)"
    },
    "topic": [
      "Electricity & Magnetism",
      "Electric Current and Resistance",
      "DC Circuits",
      "Kirchhoff's Current Law"
    ]
