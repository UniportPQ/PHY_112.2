  {
    "type": "Question",
    "name": "Question 16 @ 2019/2020",
    "Question": {
      "content": "The relation between currents in the diagram above is:",
      "type": "OBJ",
      "options": [
        "\\( I_1 = I_2 = I_3 = I_4 = I_5 \\)",
        "\\( I_1 + I_4 + I_3 = I_5 + I_2 \\)",
        "\\( I_1 - I_5 = I_2 - I_3 - I_4 \\)",
        "\\( I_1 + I_5 = I_2 + I_3 + I_4 \\)"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "\\( I_1 + I_5 = I_2 + I_3 + I_4 \\)"
    },
    "Explanation": {
      "type": "string",
      "content": "By Kirchhoff's current law (junction rule), the sum of currents entering a junction equals the sum leaving. Assuming \\(I_1\\) and \\(I_5\\) enter while \\(I_2\\), \\(I_3\\), and \\(I_4\\) exit, the correct relation is \\(I_1 + I_5 = I_2 + I_3 + I_4\\)."
    },
    "topic": [
      "Electricity & Magnetism",
      "Electric Current and Resistance",
      "DC Circuits",
      "Kirchhoff's Current Law"
    ]
  },
  {
    "type": "Question",
    "name": "Question 20 @ 2019/2020",
    "Question": {
      "content": "If the length and diameter of a conductor are doubled, the resistance:",
      "type": "OBJ",
      "options": [
        "Remains same",
        "Doubles",
        "Halves",
        "Four times"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "Halves"
    },
    "Explanation": {
      "type": "string",
      "content": "Resistance \\(R = \\rho\\frac{L}{A}\\). Doubling length \\(L\\) and diameter (quadrupling area \\(A\\)) gives \\(R' = \\rho\\frac{2L}{4A} = \\frac{1}{2}R\\)."
    },
    "topic": [
      "Electricity & Magnetism",
      "Electric Current and Resistance"
    ]
  },
