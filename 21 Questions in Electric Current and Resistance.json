  {
    "type": "Question",
    "name": "Question 33 @ 2019/2020",
    "Question": {
      "content": "When temperature increases, the resistance of conductor:",
      "type": "OBJ",
      "options": [
        "increases",
        "decreases",
        "remains constant",
        "vanishes"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "increases"
    },
    "Explanation": {
      "type": "string",
      "content": "For conductors, increased temperature causes more lattice vibrations, which scatter electrons and increase resistance. This is described by the temperature coefficient of resistance: \\(R = R_0[1 + \\alpha(T - T_0)]\\) where \\(\\alpha\\) is positive for conductors."
    },
    "topic": [
      "Electric Current and Resistance",
      "Conductors",
      "Temperature Effects"
    ]
  },
