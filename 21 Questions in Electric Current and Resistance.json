    "Answer": {
      "type": "string",
      "content": "\\(V = e - Ir\\)"
    },
    "Explanation": {
      "type": "string",
      "content": "Terminal voltage \\(V\\) equals EMF \\(e\\) minus the voltage drop across internal resistance (\\(Ir\\))."
