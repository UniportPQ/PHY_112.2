      "options": [
        "Conductors",
        "Transistors",
        "Diodes",
        "Electric Areas"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "Conductors"
    },
    "Explanation": {
      "type": "string",
      "content": "Ohm's law (\\(V = IR\\)) applies to ohmic materials (e.g., conductors) where resistance is constant. Non-ohmic devices (transistors, diodes) violate this law."
