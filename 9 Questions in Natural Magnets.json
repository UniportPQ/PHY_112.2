  {
    "type": "Question",
    "name": "Question 56 @ 2018/2019",
    "Question": {
      "content": "The angle between the geographical and magnetic meridians at a place is called the",
      "type": "OBJ",
      "options": [
        "angle of declination",
        "angle of dip",
        "magnetic meridian",
        "dip circle"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "angle of declination"
    },
    "Explanation": {
      "type": "string",
      "content": "The **angle of declination** measures the horizontal angle between true north (geographical meridian) and magnetic north (magnetic meridian). The angle of dip (inclination) is the vertical tilt of Earth's magnetic field."
    },
    "topic": [
      "Geomagnetism",
