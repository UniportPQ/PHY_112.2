  {
    "type": "Question",
    "name": "Question 37 @ 2019/2020",
    "Question": {
      "content": "The force between two magnetic poles varies with the distance between them. The variation is ___ to the square of that distance.",
      "type": "OBJ",
      "options": [
        "equal",
        "greater than",
        "directly proportional",
        "inversely proportional"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "inversely proportional"
    },
    "Explanation": {
      "type": "string",
      "content": "According to Coulomb's law for magnetism, the force between two magnetic poles is inversely proportional to the square of the distance between them: \\(F \\propto \\frac{1}{r^2}\\)."
    },
    "topic": [
      "Electricity & Magnetism",
      "Magnetic Fields",
      "Magnetic Pole",
      "Properties of Magnets",
      "Inverse Square Law"
    ]
  },
