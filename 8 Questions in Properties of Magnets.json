    "type": "Question",
    "name": "Question 15 @ 2019/2020",
    "Question": {
      "content": "Which of the following is not a property of a magnet?",
      "type": "OBJ",
      "options": [
        "Attracts and repels other magnetic materials",
        "Always settles in a N-S direction when freely suspended",
        "Magnetic pole strength is constantly varying",
        "Can impart magnetic property to other materials"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "Magnetic pole strength is constantly varying"
    },
    "Explanation": {
      "type": "string",
      "content": "A magnet's pole strength is fixed unless demagnetized or altered externally. The other options are fundamental properties of magnets."
    },
