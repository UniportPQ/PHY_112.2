  {
    "type": "Question",
    "name": "Question 25 @ 2019/2020",
    "Question": {
      "content": "The ability of a material to retain magnetism after removing the magnetizing field is called:",
      "type": "OBJ",
      "options": [
        "Retentivity",
        "Coercivity",
        "Dipole",
        "Remanence",
        "Monopole"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "Remanence"
    },
    "Explanation": {
      "type": "string",
      "content": "Remanence (or residual magnetism) is the magnetization left behind after the external field is removed. Retentivity is the capacity to retain this magnetism, but 'Remanence' is the standard term for the property itself."
    },
    "topic": [
      "Electricity & Magnetism",
      "Magnetic Fields",
      "Properties of Magnets",
      "Retentivity"
    ]
  },
  {
    "type": "Question",
    "name": "Question 35 @ 2019/2020",
    "Question": {
      "content": "The space outside the magnet where its poles exert force is called?",
      "type": "OBJ",
      "options": [
        "magnetic field",
        "electric field",
        "electromagnetic field",
        "free space field"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "magnetic field"
    },
    "Explanation": {
      "type": "string",
      "content": "A magnetic field is the region around a magnet where magnetic forces act on other magnets or moving charges. It is represented by field lines emerging from the north pole and entering the south pole."
    },
    "topic": [
      "Magnetic Fields",
      "Magnetic Pole",
      "Properties of Magnets",
      "Natural Magnets"
    ]
  },
  {
