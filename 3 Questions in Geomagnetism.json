    "Question": {
      "content": "The angle between the direction of the earth’s resultant field and the horizontal is called the?",
      "type": "OBJ",
      "options": [
        "angle of dip",
        "angle of declination",
        "dip circle",
        "angle of variation"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "angle of dip"
    },
    "Explanation": {
      "type": "string",
      "content": "The angle of dip (or inclination) measures the tilt of Earth’s magnetic field relative to the horizontal plane."
    },
    "topic": [
      "Electromagnetism",
      "Natural Magnets",
      "Geomagnetism"
    ]
  },
  {
    "type": "Question",
    "name": "Question 56 @ 2018/2019",
    "Question": {
      "content": "The angle between the geographical and magnetic meridians at a place is called the",
      "type": "OBJ",
      "options": [
        "angle of declination",
        "angle of dip",
        "magnetic meridian",
        "dip circle"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "angle of declination"
    },
    "Explanation": {
      "type": "string",
      "content": "The **angle of declination** measures the horizontal angle between true north (geographical meridian) and magnetic north (magnetic meridian). The angle of dip (inclination) is the vertical tilt of Earth's magnetic field."
    },
    "topic": [
      "Geomagnetism",
      "Natural Magnets",
      "Electromagnetism"
    ]
  },
