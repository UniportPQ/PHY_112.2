  {
    "type": "Question",
    "name": "Question 13 @ 2017/2018",
    "Question": {
      "content": "A 1\\(\\mu\\)F capacitor is charged using a constant current of 10\\(\\mu\\)A for 20seconds. What energy is finally stored by the capacitor?",
      "type": "OBJ",
      "options": [
        "2 × 10³J",
        "2 × 10²J",
        "2 × 10¹J",
        "2 × 10⁰J"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "2 × 10¹J"
    },
    "Explanation": {
      "type": "string",
      "content": "Charge \\( Q = I \\cdot t = 10 \\times 10^{-6} \\cdot 20 = 2 \\times 10^{-4}C \\). Voltage \\( V = \\frac{Q}{C} = \\frac{2 \\times 10^{-4}}{1 \\times 10^{-6}} = 200V \\). Energy \\( E = \\frac{1}{2} C V^2 = \\frac{1}{2} \\times 1 \\times 10^{-6} \\times (200)^2 = 0.5 \\times 10^{-6} \\times 40000 = 2 \\times 10^1J \\)."
    },
    "topic": [
      "Capacitors and Dielectrics",
      "DC Circuits",
      "Current and Resistance",
      "Electric Potential Energy"
    ]
  },
