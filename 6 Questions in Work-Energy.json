  {
    "type": "Question",
    "name": "Question 35 @ 2018/2019",
    "Question": {
      "content": "Suppose we have two charges of 4µC and -6µC with an initial separation of r = 3m. What is the change in potential energy if we increase the separation to 8m?",
      "type": "OBJ",
      "options": [
        "45mJ",
        "72mJ",
        "27mJ",
        "99mJ"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "27mJ"
    },
    "Explanation": {
      "type": "string",
      "content": "<p>Change in potential energy:</p> \\[ ΔU = kq_1q_2\\left(\\frac{1}{r_f} - \\frac{1}{r_i}\\right) \\] \\[ ΔU = (9×10^9)(4×10^{-6})(-6×10^{-6})\\left(\\frac{1}{8} - \\frac{1}{3}\\right) \\] \\[ ΔU = 0.027J = 27mJ \\]"
    },
    "topic": [
      "Electromagnetism",
      "Electrostatics",
      "Electric Charge",
      "Electric Potential",
      "Coulomb's Law",
      "Work-Energy"
    ]
  },
