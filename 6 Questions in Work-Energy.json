      "content": "How much does it cost to burn a 100W light bulb for 24hrs if electricity costs 100 per kWh?",
      "type": "OBJ",
      "options": [
        "120",
        "240",
        "200",
        "480"
      ]
    },
    "Answer": {
      "type": "string",
