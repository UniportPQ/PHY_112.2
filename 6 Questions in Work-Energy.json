  {
    "type": "Question",
    "name": "Question 11 @ 2018/2019",
    "Question": {
      "content": "A 5J of work is done in moving a 0.025C of positive charge from a point A to point B. What is the difference in potential at this two points A and B?",
      "type": "OBJ",
      "options": [
        "0.125V",
        "200V",
        "0.05V",
        "None"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "200V"
    },
    "Explanation": {
      "type": "string",
      "content": "<p>Potential difference is calculated by:</p> \\[ V = \\frac{W}{Q} \\] <p>Where:<br>W = 5J<br>Q = 0.025C</p> \\[ V = \\frac{5}{0.025} = 200V \\]"
    },
    "topic": [
      "Electromagnetism",
      "Electrostatics",
      "Electric Potential",
      "Work-Energy"
    ]
  },
  {
    "type": "Question",
    "name": "Question 12 @ 2018/2019",
    "Question": {
      "content": "A charge of 1C flows from 100V outlet through a 100W light bulb each second. How much work is done each second by this electrical source?",
      "type": "OBJ",
      "options": [
        "1000J",
        "0.1J",
        "10J",
        "100J"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "100J"
    },
    "Explanation": {
      "type": "string",
      "content": "<p>Work done is calculated by:</p> \\[ W = V × Q \\] <p>Where:<br>V = 100V<br>Q = 1C</p> \\[ W = 100 × 1 = 100J \\] <p>Note: The 100W rating is extra information not needed for this calculation.</p>"
    },
    "topic": [
      "Electromagnetism",
      "Electric Potential",
      "Work-Energy",
      "Power"
    ]
  },
