  {
    "type": "Question",
    "name": "Question 26 @ 2018/2019",
    "Question": {
      "content": "Two resistors 40Ω and 80Ω are connected in series with a 12V battery. How much power is dissipated in the 40Ω resistor?",
      "type": "OBJ",
      "options": [
        "4W",
        "8W",
        "81W",
        "36W"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "4W"
    },
    "Explanation": {
      "type": "string",
      "content": "<p><b>Step 1:</b> Calculate total resistance in series:</p> \\[ R_{total} = 40Ω + 80Ω = 120Ω \\] <p><b>Step 2:</b> Find current using Ohm's Law:</p> \\[ I = \\frac{V}{R_{total}} = \\frac{12V}{120Ω} = 0.1A \\] <p><b>Step 3:</b> Calculate power in 40Ω resistor:</p> \\[ P = I^2R = (0.1A)^2 \\times 40Ω = 0.4W \\] <p>Note: The correct answer should be 0.4W, but 4W is the closest option. There may be an error in the question values.</p>"
    },
    "topic": [
      "Electromagnetism",
      "Circuit Analysis",
      "Series Circuits",
      "Electrical Resistance",
      "Ohm's Law",
      "Current",
      "Power"
    ]
  },
