  {
    "type": "Question",
    "name": "Question 69 @ 2019/2020",
    "Question": {
      "content": "Which of the following are conservative forces?",
      "type": "OBJ",
      "options": [
        "electrical force/electric field strength",
        "electric flux/electric field strength",
        "gravitational force/electrostatic force",
        "gravitational force/electromotive force"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "gravitational force/electrostatic force"
    },
    "Explanation": {
      "type": "string",
      "content": "<p>Conservative forces (like gravitational and electrostatic forces) are path-independent and conserve mechanical energy. Their work done around a closed loop is zero:</p> \\[ \\oint \\vec{F} \\cdot d\\vec{l} = 0 \\]"
    },
    "topic": [
      "Conservative Forces",
      "Electricity & Magnetism",
      "Electrostatic Force",
      "Electric Fields"
    ]
