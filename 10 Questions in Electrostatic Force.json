  {
    "type": "Question",
    "name": "Question 57 @ 2019/2020",
    "Question": {
      "content": "Coulomb’s law of force between two point charges is given by:",
      "type": "OBJ",
      "options": [
        "\\(F = \\frac{1}{4\\pi\\epsilon_0} \\frac{Q}{R^2}\\)",
        "\\(F = 4\\pi\\epsilon_0 R^2 Q_1 Q_2\\)",
        "\\(F = 4\\pi\\epsilon_0 R^2 Q\\)",
        "\\(F = \\frac{1}{4\\pi\\epsilon_0} \\frac{Q_1 Q_2}{R^2}\\)"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "\\(F = \\frac{1}{4\\pi\\epsilon_0} \\frac{Q_1 Q_2}{R^2}\\)"
    },
    "Explanation": {
      "type": "string",
      "content": "Coulomb's law states the force between charges \\(Q_1\\) and \\(Q_2\\) separated by distance \\(R\\) is \\(F = \\frac{1}{4\\pi\\epsilon_0} \\frac{Q_1 Q_2}{R^2}\\), where \\(\\epsilon_0\\) is permittivity."
    },
    "topic": [
      "Electrostatic Force",
      "Electrostatics",
      "Inverse Square Law",
      "Permittivity",
      "Electricity & Magnetism"
    ]
  },
  {
    "type": "Question",
    "name": "Question 60 @ 2019/2020",
    "Question": {
      "content": "The region around a point charge where a charged body experiences force is called:",
      "type": "OBJ",
      "options": [
        "Electric flux",
        "Magnetic flux density",
        "Electric field",
        "Field point"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "Electric field"
    },
    "Explanation": {
      "type": "string",
      "content": "An electric field \\(\\vec{E}\\) is defined as the force per unit charge: \\(\\vec{E} = \\frac{\\vec{F}}{q}\\). It extends radially from point charges."
    },
