    "type": "Question",
    "name": "Question 42 @ 2019/2020",
    "Question": {
      "content": "A positive test charge q released near a fixed positive charge Q moves away with:",
      "type": "OBJ",
      "options": [
        "increasing acceleration",
        "decreasing acceleration",
        "constant velocity",
        "constant acceleration"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "decreasing acceleration"
    },
    "Explanation": {
      "type": "string",
      "content": "As \\(q\\) moves away, the repulsive Coulomb force \\(F = k\\frac{Qq}{r^2}\\) decreases with distance, reducing acceleration."
    },
