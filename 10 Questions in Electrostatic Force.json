  {
    "type": "Question",
    "name": "Question 65 @ 2019/2020",
    "Question": {
      "content": "Which of the following is not true?",
      "type": "OBJ",
      "options": [
        "Coulomb's law is valid for point charges only",
        "Coulomb's law is the force on either charge due to the other",
        "Coulomb's law decreases as the distance from source increases",
        "the direction of the Coulomb's force is anti-parallel to the line joining the charge bodies"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "the direction of the Coulomb's force is anti-parallel to the line joining the charge bodies"
    },
    "Explanation": {
      "type": "string",
      "content": "<p>Coulomb's force direction is <b>parallel</b> (for like charges) or <b>anti-parallel</b> (for opposite charges) to the line joining the charges. The incorrect statement reverses this logic. Coulomb's law:</p> \\[ F = k\\frac{|q_1q_2|}{r^2} \\]"
    },
    "topic": [
      "Coulomb's Law",
      "Electrostatic Force",
      "Electrostatics",
      "Inverse Square Law",
      "Electricity & Magnetism"
    ]
  },
  {
    "type": "Question",
    "name": "Question 66 @ 2019/2020",
    "Question": {
      "content": "Calculate the electrostatic force between two protons of charges \\(1.6 \\times 10^{-19} \\, \\text{C}\\) separated by a distance of \\(2.0 \\times 10^{-15} \\, \\text{m}\\)",
      "type": "OBJ",
      "options": [
        "15N",
        "30N",
        "40N",
        "60N"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "60N"
    },
    "Explanation": {
      "type": "string",
      "content": "<p>Using Coulomb's law:</p> \\[ F = k\\frac{q_1q_2}{r^2} = (9\\times10^9)\\frac{(1.6\\times10^{-19})^2}{(2\\times10^{-15})^2} \\] \\[ F = \\frac{2.304\\times10^{-28}}{4\\times10^{-30}} = 57.6N \\approx 60N \\]"
    },
    "topic": [
      "Electrostatic Force",
      "Coulomb's Law",
      "Electrostatics",
      "Electricity & Magnetism",
      "Inverse Square Law"
    ]
