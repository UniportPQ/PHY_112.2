    "name": "Question 5 @ 2019/2020",
    "Question": {
      "content": "Find the electrostatic force between an α-particle (2e) and an electron (e) 10⁻³m apart (e = 1.6×10⁻¹⁹C).",
      "type": "OBJ",
      "options": [
        "0.046N",
        "0.46N",
        "4.6N",
        "46N"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "0.046N"
    },
    "Explanation": {
      "type": "string",
      "content": "\\(F = k_e \\frac{|q_1 q_2|}{r^2} = (8.99\\times10^9) \\frac{|(2 \\times 1.6\\times10^{-19})(1.6\\times10^{-19})|}{(10^{-3})^2} \\approx 0.046N\\)"
    },
    "topic": [
      "Electrostatic Force",
      "Electricity & Magnetism"
    ]
