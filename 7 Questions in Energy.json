    "type": "Question",
    "name": "Question 43 @ 2016/2017",
    "Question": {
      "content": "Three points (A, B, C) have potentials 8.0V, 4.0V, and -2.0V. A negative charge at B is released. Which way will it move?",
      "type": "OBJ",
      "options": [
        "Toward A",
        "Toward B",
        "It will not move",
        "Toward C"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "Toward C"
    },
    "Explanation": {
      "type": "string",
      "content": "Negative charges move <b>from lower to higher potential</b>. Since point C (-2.0V) has lower potential than B (4.0V), the charge moves <b>toward C</b>."
    },
