    "name": "Question 51 @ 2016/2017",
    "Question": {
      "content": "Which of the following are conservative forces?",
      "type": "OBJ",
      "options": [
        "Electrostatic force/Electric field strength",
        "Electric flux/Electric field strength",
        "Gravitation force/Electrostatic force",
        "Gravitation force/Electromotive force"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "Gravitation force/Electrostatic force"
    },
    "Explanation": {
      "type": "string",
      "content": "Conservative forces (like gravity and electrostatic force) don't lose energy when things move in loops. Just like a rollercoaster, you end with the same energy you started with!"
    },
