    "Question": {
      "content": "Which statement is not true about a charge released in an electric field?",
      "type": "OBJ",
      "options": [
        "Positive charge moves to lower potential",
        "Positive charge moves to lower potential energy",
        "Negative charge moves to higher potential",
        "Negative charge moves to higher potential energy"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "Negative charge moves to higher potential energy"
    },
    "Explanation": {
      "type": "string",
      "content": "A negative charge naturally moves to <b>higher potential</b> (lower potential energy). Option (d) incorrectly states it moves to higher potential energy, which violates energy minimization principles."
