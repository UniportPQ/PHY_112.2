  {
    "type": "Question",
    "name": "Question 55 @ 2016/2017",
    "Question": {
      "content": "Which statement describes Kirchhoff's Rules?",
      "type": "OBJ",
      "options": [
        "Currents into a junction > currents out",
        "Currents in = currents out, and loop voltages add to zero",
        "Only loop voltages matter",
        "None of the above"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "Currents in = currents out, and loop voltages add to zero"
    },
    "Explanation": {
      "type": "string",
      "content": "Kirchhoff's Rules are like water pipes: what flows in must flow out (current rule), and all hills/drops in a loop cancel out (voltage rule)."
    },
