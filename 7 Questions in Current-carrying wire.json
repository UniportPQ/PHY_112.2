    "type": "Question",
    "name": "Question 33 @ 2017/2018",
    "Question": {
      "content": "Calculate the magnetic force on a 240m length of wire stretched between two towers carrying a 150A current. The Earth's magnetic field is 5.0×10⁻⁵T makes an angle 60° with the wire",
      "type": "OBJ",
      "options": [
        "1.56N",
        "0.04N",
        "1.89N",
        "0.52N"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "1.56N"
    },
    "Explanation": {
      "type": "string",
      "content": "Magnetic force \\( F = I L B \\sin\\theta \\), where \\( I = 150A \\), \\( L = 240m \\), \\( B = 5.0 × 10^{-5}T \\), \\(\\theta = 60^\\circ \\), \\(\\sin 60^\\circ = \\sqrt{3}/2 \\approx 0.866\\). Thus, \\( F = 150 × 240 × 5.0 × 10^{-5} × 0.866 \\approx 1.56N \\)."
    },
    "topic": [
      "Magnetic Fields",
      "Magnetic Force",
      "Electromagnetism",
      "Current-carrying wire"
    ]
  },
