    "type": "Question",
    "name": "Question 48 @ 2019/2020",
    "Question": {
      "content": "Find the electrostatic force between an α-particle (2e) and an electron 10⁻¹³m apart (e = 1.6×10⁻¹⁹C).",
      "type": "OBJ",
      "options": [
        "0.046N",
        "0.46N",
        "4.6N",
        "46N"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "4.6N"
    },
    "Explanation": {
      "type": "string",
      "content": "\\(F = k_e \\frac{|q_1 q_2|}{r^2} = (9\\times10^9) \\frac{|(2 \\times 1.6\\times10^{-19})(1.6\\times10^{-19})|}{(10^{-13})^2} \\approx 4.6N\\)."
    },
    "topic": [
      "Electrostatic Force",
      "Electrostatics",
      "Electricity & Magnetism",
      "Inverse Square Law",
      "Permittivity",
      "SI Units"
    ]
  },
