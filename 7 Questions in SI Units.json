    "Question": {
      "content": "One electron-volt (1 eV) is equivalent to:",
      "type": "OBJ",
      "options": [
        "1.6×10⁻¹⁹ J",
        "1.6×10⁻¹⁹ V",
        "1.6×10⁻¹⁶ J",
        "6.0×10⁻¹⁹ J"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "1.6×10⁻¹⁹ J"
    },
    "Explanation": {
      "type": "string",
      "content": "1 eV is the energy gained by an electron accelerated through 1 V: \\(1 eV = e \\times 1 V = 1.6\\times10^{-19} J\\)."
    },
