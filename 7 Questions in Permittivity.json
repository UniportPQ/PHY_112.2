    "type": "Question",
    "name": "Question 44 @ 2019/2020",
    "Question": {
      "content": "A parallel plate capacitor (A=2m², d=1m) stores 1.77×10⁻¹¹C. Find the voltage.",
      "type": "OBJ",
      "options": [
        "1V",
        "2V",
        "3V",
        "4V"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "1V"
    },
    "Explanation": {
      "type": "string",
      "content": "\\(C = \\frac{\\epsilon_0 A}{d} \\approx 17.7\\times10^{-12}F\\). \\(V = \\frac{Q}{C} = \\frac{1.77\\times10^{-11}C}{17.7\\times10^{-12}F} = 1V\\)."
    },
    "topic": [
      "Electricity & Magnetism",
      "Capacitance",
      "Parallel Plate Capacitor",
      "Electric Potential",
