    "Question": {
      "content": "Kirchhoff’s first rule is?",
      "type": "OBJ",
      "options": [
        "∑I = 0",
        "∑R = 0",
        "∑V = 0",
        "∑I = 0"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "∑I = 0"
    },
    "Explanation": {
      "type": "string",
      "content": "Kirchhoff’s junction rule (first law) states that the algebraic sum of currents entering a junction equals zero (charge conservation)."
