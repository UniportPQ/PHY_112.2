  {
    "type": "Question",
    "name": "Question 19 @ 2017/2018",
    "Question": {
      "content": "The emf of a cell, E is 3V which is balanced across 1 - 100cm of a potentiometer wire. The cell is then shunted by the resistance Rs = 30\\(\\Omega\\). The required balance length is Ls = 80cm. What is the value of the current flowing through the shunt?",
      "type": "OBJ",
      "options": [
        "0.125A",
        "0.335A",
        "0.225A",
        "0.250A"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "0.125A"
    },
    "Explanation": {
      "type": "string",
      "content": "Initial balance length = 100cm for 3V, so potential gradient = \\( \\frac{3}{100} = 0.03V/cm \\). New balance length = 80cm, so new voltage = \\( 0.03 \\times 80 = 2.4V \\). Shunt current \\( I_s = \\frac{E - V}{R_s} = \\frac{3 - 2.4}{30} = \\frac{0.6}{30} = 0.125A \\)."
    },
    "topic": [
      "Electrical Measurement Instruments",
      "DC Circuits",
      "Current and Resistance",
      "Electric Potential"
    ]
  },
