    "type": "Question",
    "name": "Question 16 @ 2018/2019",
    "Question": {
      "content": "Four capacitors of 16µF each are connected in series, determine the effective capacitance of the combination",
      "type": "OBJ",
      "options": [
        "64µF",
        "32µF",
        "4µF",
        "2µF"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "4µF"
    },
    "Explanation": {
      "type": "string",
      "content": "<p>For capacitors in series:</p> \\[ \\frac{1}{C_{eq}} = \\frac{1}{C_1} + \\frac{1}{C_2} + \\frac{1}{C_3} + \\frac{1}{C_4} \\] <p>With all C = 16µF:</p> \\[ \\frac{1}{C_{eq}} = 4 × \\frac{1}{16} = \\frac{1}{4} \\] \\[ C_{eq} = 4µF \\]"
    },
    "topic": [
      "Electromagnetism",
      "Capacitance",
      "Electrostatics",
      "Series Circuits"
    ]
  },
