  {
    "type": "Question",
    "name": "Question 34 @ 2019/2020",
    "Question": {
      "content": "Capacitance of a capacitor depends upon?",
      "type": "OBJ",
      "options": [
        "size of plate",
        "distance between plates",
        "nature of dielectric between plate",
        "all of the above"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "all of the above"
    },
    "Explanation": {
      "type": "string",
      "content": "Capacitance \\(C\\) is determined by: (1) Plate area \\(A\\) (\\(C \\propto A\\)), (2) Distance between plates \\(d\\) (\\(C \\propto 1/d\\)), and (3) Dielectric material's permittivity \\(\\epsilon\\) (\\(C = \\frac{\\epsilon A}{d}\\))."
    },
    "topic": [
      "Capacitance",
      "Parallel Plate Capacitor",
      "Dielectric",
      "Electrostatics",
      "Permittivity"
    ]
  },
  {
    "type": "Question",
    "name": "Question 41 @ 2018/2019",
    "Question": {
      "content": "A parallel plate capacitor has plates of dimensions 2.0cm by 3.0cm separated by a 1.0cm thickness of paper. Find its capacitance (K for paper = 3.7)",
      "type": "OBJ",
      "options": [
        "18.0pF",
        "20pF",
        "15.0pF",
        "20.0pF"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "20.0pF"
    },
    "Explanation": {
      "type": "string",
      "content": "<p>Capacitance formula: \\[ C = \\frac{κε_0A}{d} \\] \\[ A = 0.02m × 0.03m = 6×10^{-4}m^2 \\] \\[ d = 0.01m \\] \\[ C = \\frac{3.7×8.85×10^{-12}×6×10^{-4}}{0.01} ≈ 20pF \\]</p>"
    },
    "topic": [
      "Electromagnetism",
      "Capacitance",
      "Electrostatics",
      "Dielectric"
    ]
  },
  {
    "type": "Question",
    "name": "Question 44 @ 2018/2019",
    "Question": {
      "content": "What happens to a dielectric when inserted between the plates of a capacitor?",
      "type": "OBJ",
      "options": [
        "the electric field is increased",
        "the electric field is weakened",
        "the electric field is doubled",
        "the electric field is zero"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "the electric field is weakened"
    },
    "Explanation": {
      "type": "string",
      "content": "A dielectric reduces the effective electric field (E = E₀/κ) by polarizing in response to the field, where κ is the dielectric constant."
    },
