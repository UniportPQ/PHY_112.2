  {
    "type": "Question",
    "name": "Question 43 @ 2017/2018",
    "Question": {
      "content": "A long straight wire 2mm in diameter is carrying a current of 5A. Find the magnetic field at a distance of 40cm from the wire",
      "type": "OBJ",
      "options": [
        "2.5×10⁻⁶T",
        "15.8×10⁻⁶T",
        "60.4×10⁻⁶T",
        "45.9T"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "2.5×10⁻⁶T"
    },
    "Explanation": {
      "type": "string",
      "content": "Magnetic field \\( B = \\frac{\\mu_0 I}{2\\pi r} \\), where \\( \\mu_0 = 4\\pi × 10^{-7}Tm/A \\), \\( I = 5A \\), \\( r = 0.4m \\). Thus, \\( B = \\frac{4\\pi × 10^{-7} × 5}{2\\pi × 0.4} = \\frac{2 × 10^{-6}}{0.4} = 2.5 × 10^{-6}T \\)."
    },
    "topic": [
      "Electricity & Magnetism",
      "Magnetic Fields",
      "Current-carrying wire",
      "Ampere's Law"
    ]
  },
