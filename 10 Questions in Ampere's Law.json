    "Question": {
      "content": "Find the current in a magnetic field of 1.4×10⁻³T at the centre of a circular coil of radius 20cm having 15 closely wound turns",
      "type": "OBJ",
      "options": [
        "30A",
        "50A",
        "70A",
        "95A"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "50A"
    },
    "Explanation": {
      "type": "string",
      "content": "Magnetic field at center \\( B = \\frac{\\mu_0 N I}{2R} \\), where \\( B = 1.4 × 10^{-3}T \\), \\( N = 15 \\), \\( R = 0.2m \\), \\( \\mu_0 = 4\\pi × 10^{-7}Tm/A \\). Thus, \\( 1.4 × 10^{-3} = \\frac{4\\pi × 10^{-7} × 15 × I}{2 × 0.2} \\), \\( I = \\frac{1.4 × 10^{-3} × 0.4}{6\\pi × 10^{-7}} \\approx 50A \\)."
    },
    "topic": [
      "Magnetic Fields",
      "Current Loops",
      "Ampere's Law",
      "Electromagnetism"
    ]
  },
