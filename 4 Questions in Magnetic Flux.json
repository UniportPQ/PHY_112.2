    "type": "Question",
    "name": "Question 50 @ 2019/2020",
    "Question": {
      "content": "Faraday’s law of electromagnetic induction is expressed as:",
      "type": "OBJ",
      "options": [
        "\\(E = \\frac{d\\Phi_B}{dt}\\)",
        "\\(E = -\\frac{d\\Phi_B}{dt}\\)",
        "\\(E = \\int \\Phi_B dt\\)",
        "\\(E = -\\int \\Phi_B dt\\)"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "\\(E = -\\frac{d\\Phi_B}{dt}\\)"
    },
    "Explanation": {
      "type": "string",
      "content": "Faraday’s law states that the induced EMF (\\(E\\)) equals the negative rate of change of magnetic flux (\\(\\Phi_B\\)). The negative sign indicates Lenz’s law."
    },
    "topic": [
      "Faraday's Law of Induction",
      "Magnetic Fields",
      "Magnetic Flux",
      "Electricity & Magnetism"
    ]
