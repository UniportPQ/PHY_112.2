  {
    "type": "Question",
    "name": "Question 9 @ 2017/2018",
    "Question": {
      "content": "A capacitor is to be built which will store enough energy to light a 50W energy bulb for 30mins. If available potential difference is 200V, what capacitance is needed?",
      "type": "OBJ",
      "options": [
        "90F",
        "45F",
        "6F",
        "9F"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "90F"
    },
    "Explanation": {
      "type": "string",
      "content": "Energy stored in a capacitor is \\( E = \\frac{1}{2} C V^2 \\). Energy required = 50W \\times 1800s = 90000J. Thus, \\( 90000 = \\frac{1}{2} C (200)^2 \\), so \\( C = \\frac{2 \\times 90000}{40000} = 90F \\)."
    },
    "topic": [
      "Capacitors and Dielectrics",
      "Electric Potential",
      "Electric Potential Energy"
    ]
  },
  {
    "type": "Question",
    "name": "Question 13 @ 2017/2018",
    "Question": {
      "content": "A 1\\(\\mu\\)F capacitor is charged using a constant current of 10\\(\\mu\\)A for 20seconds. What energy is finally stored by the capacitor?",
      "type": "OBJ",
      "options": [
        "2 × 10³J",
        "2 × 10²J",
        "2 × 10¹J",
        "2 × 10⁰J"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "2 × 10¹J"
    },
    "Explanation": {
      "type": "string",
      "content": "Charge \\( Q = I \\cdot t = 10 \\times 10^{-6} \\cdot 20 = 2 \\times 10^{-4}C \\). Voltage \\( V = \\frac{Q}{C} = \\frac{2 \\times 10^{-4}}{1 \\times 10^{-6}} = 200V \\). Energy \\( E = \\frac{1}{2} C V^2 = \\frac{1}{2} \\times 1 \\times 10^{-6} \\times (200)^2 = 0.5 \\times 10^{-6} \\times 40000 = 2 \\times 10^1J \\)."
    },
    "topic": [
      "Capacitors and Dielectrics",
