  {
    "type": "Question",
    "name": "Question 25 @ 2017/2018",
    "Question": {
      "content": "Which of the following is incorrect?",
      "type": "OBJ",
      "options": [
        "The sum of all the charges within the Gaussian surface is Zero",
        "The region around a point charge in which an electric force can be experienced by a charged body is the electric flux",
        "Coulombs law is given by K \\(\\alpha\\) \\(\\frac{q_1q_2}{r^2}\\)",
        "The electrostatic potential difference between two points in a region is work done in carrying a test charge from one point to another"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "The region around a point charge in which an electric force can be experienced by a charged body is the electric flux"
    },
    "Explanation": {
      "type": "string",
      "content": "The region around a point charge where force is experienced is the electric field, not flux. Electric flux is the measure of field lines passing through a surface."
    },
