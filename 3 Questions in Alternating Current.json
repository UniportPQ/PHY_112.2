    "type": "Question",
    "name": "Question 66 @ 2018/2019",
    "Question": {
      "content": "What is the frequency of the generator?",
      "type": "OBJ",
      "options": [
        "553Hz",
        "120Hz",
        "88Hz",
        "60Hz"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "88Hz"
    },
    "Explanation": {
      "type": "string",
      "content": "Angular frequency \\( \\omega = 553 \\, \\text{rad/s} \\). Frequency \\( f = \\frac{\\omega}{2\\pi} = \\frac{553}{6.28} \\approx 88 \\, \\text{Hz} \\)."
    },
    "topic": [
      "Electromagnetism",
      "Alternating Current"
    ]
