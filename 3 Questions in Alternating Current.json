    "name": "Question 65 @ 2018/2019",
    "Question": {
      "content": "A generator delivers an AC voltage given by the equation \\( V = 120 \\sin 553t \\). What is the peak voltage of the generator?",
      "type": "OBJ",
      "options": [
        "120V",
        "55V",
        "12V",
        "60V"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "120V"
    },
    "Explanation": {
      "type": "string",
      "content": "The general form is \\( V = V_0 \\sin(\\omega t) \\), where \\( V_0 \\) is the peak voltage. Here, \\( V_0 = 120 \\, \\text{V} \\)."
    },
    "topic": [
      "Physics",
      "Electromagnetism",
      "Circuit Analysis",
      "Electric Potential",
      "Alternating Current"
    ]
