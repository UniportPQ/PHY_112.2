  {
    "type": "Question",
    "name": "Question 29 @ 2021/2022",
    "Question": {
      "content": "How much energy can be stored by a 25µF capacitor charged to a potential difference of 12V?",
      "type": "OBJ",
      "options": [
        "1.5x10⁻³J",
        "1.8x10⁻³J",
        "3.0x10⁻³J",
        "3.6x10⁻³J"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "1.8x10⁻³J"
    },
    "Explanation": {
      "type": "string",
      "content": "The energy stored in a capacitor is given by \\( U = \\frac{1}{2} C V^2 \\), where \\( C = 25 \\mu\\text{F} = 25 \\times 10^{-6} \\text{F} \\) and \\( V = 12 \\text{V} \\). So, \\( U = \\frac{1}{2} \\times 25 \\times 10^{-6} \\times (12)^2 = \\frac{1}{2} \\times 25 \\times 10^{-6} \\times 144 = 12.5 \\times 144 \\times 10^{-6} = 1800 \\times 10^{-6} = 1.8 \\times 10^{-3} \\text{J} \\). This makes 1.8x10⁻³J the correct answer. The other options—1.5x10⁻³J, 3.0x10⁻³J, and 3.6x10⁻³J—do not match this calculation."
    },
    "topic": [
      "Capacitance",
      "Electric Potential",
      "Energy Storage",
      "Electrostatics",
      "Electricity & Magnetism"
    ]
  },
