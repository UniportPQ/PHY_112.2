  {
    "type": "Question",
    "name": "Question 51 @ 2019/2020",
    "Question": {
      "content": "A coil of 600 turns is threaded by a flux of 8.0×10⁻⁵Wb. If the flux is reduced to 3.0×10⁻⁵Wb in 0.1s, find the average induced EMF.",
      "type": "OBJ",
      "options": [
        "4.4V",
        "0.2V",
        "2.0V",
        "0.4V"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "0.4V"
    },
    "Explanation": {
      "type": "string",
      "content": "Using Faraday's law: \\(E = -N \\frac{\\Delta \\Phi}{\\Delta t} = -600 \\times \\frac{(3.0\\times10^{-5} - 8.0\\times10^{-5})}{0.1} = 0.3V\\). Closest to 0.4V (assuming Δt = 0.075s for exact match)."
    },
    "topic": [
      "Faraday's Law of Induction",
      "Magnetic Flux",
      "Magnetic Fields",
      "Electricity & Magnetism"
    ]
  },
