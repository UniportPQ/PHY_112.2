    "type": "Question",
    "name": "Question 53 @ 2018/2019",
    "Question": {
      "content": "An ion (q = +2e) enters a magnetic field of 1.2T at a velocity of 2.5×10⁵m/s, perpendicular to the field. Determine the force on the ion.",
      "type": "OBJ",
      "options": [
        "9.6×10⁻¹⁴N",
        "9×10⁻⁷N",
        "6.5×10⁻¹⁴N",
        "15×10⁻¹⁴N"
      ]
    },
    "Answer": {
      "type": "string",
      "content": "9.6×10⁻¹⁴N"
    },
    "Explanation": {
      "type": "string",
      "content": "F = qvBsinθ = (2×1.6×10⁻¹⁹C)(2.5×10⁵m/s)(1.2T)(sin90°) = 9.6×10⁻¹⁴N."
    },
    "topic": [
      "Electromagnetism",
      "Magnetic Force",
      "Charged Particle Motion",
      "Lorentz Force"
    ]
  },
